# API Central Cart
CENTRAL_CART_API_URL=https://api.centralcart.com.br/v1
CENTRAL_CART_API_TOKEN=seu_token_aqui
CENTRAL_CART_STORE_ID=loja.austv.net
# Segredo compartilhado p/ validar o webhook (opcional; vazio = sem verificacao)
CENTRALCART_WEBHOOK_SECRET=

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_UPDATES_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Mencao nas notificacoes de post (opcional; vazio = sem mencao).
# Use o ID de um cargo para mencionar esse cargo, ou "everyone"/"@everyone" para mencionar @everyone.
DISCORD_UPDATES_ROLE_ID=
DISCORD_CHANNEL_ID=seu_channel_id_aqui
DISCORD_BOT_TOKEN=seu_bot_token_aqui

# --- Cargos por meta de doação (Discord bot) ---
# Token do bot do Discord (precisa de Manage Roles; cargo do bot acima dos cargos de meta)
# DISCORD_BOT_TOKEN ja declarado acima na secao Discord
# ID do servidor (guild) onde os cargos vivem
DISCORD_GUILD_ID=
# Secret HMAC do webhook ORDER_APPROVED (gerado no painel da Central Cart)
CENTRALCART_ORDER_WEBHOOK_SECRET=
# (Opcional) sobrescreve os IDs de cargo por tier
DONATION_TIER_1_ROLE_ID=
DONATION_TIER_2_ROLE_ID=
DONATION_TIER_3_ROLE_ID=

# Aplicacao
PORT=3333
APP_VERSION=0.0.0
# Chave exigida (header x-api-key) nos endpoints de disparo manual /scheduler e /webhook/test
SCHEDULER_API_KEY=defina_uma_chave_secreta
